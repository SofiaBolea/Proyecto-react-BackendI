{{!-- Vista home: formulario de creación y tabla con productos existentes. --}}
<header class="text-center mb-4">
    <h1 class="display-5 text-primary">
        <i class="fas fa-boxes"></i> Gestión de Productos
    </h1>
</header>

{{#if errorMessage}}
<div class="alert alert-danger alert-dismissible fade show" role="alert">
    <strong>Error:</strong> {{errorMessage}}
    <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
</div>
{{/if}}

<div class="row">
    {{!-- Formulario para crear producto --}}
    <div class="col-md-4">
        <div class="card mb-3 shadow-sm">
            <div class="card-header bg-success text-white">
                <i class="fas fa-plus-circle"></i> Crear Nuevo Producto
            </div>
            <div class="card-body">
                <form action="/api/products" method="POST">
                    <input type="text" name="title" class="form-control mb-2" placeholder="Título del producto" required />
                    <input type="text" name="description" class="form-control mb-2" placeholder="Descripción" required />
                    <input type="text" name="code" class="form-control mb-2" placeholder="Código único (ej: AA-123)" required />
                    <div class="row">
                        <div class="col">
                            <input type="number" name="price" class="form-control mb-2" placeholder="Precio" step="0.01" required />
                        </div>
                        <div class="col">
                            <input type="number" name="stock" class="form-control mb-2" placeholder="Stock" required />
                        </div>
                    </div>
                    <input type="text" name="category" class="form-control mb-2" placeholder="Categoría" required />
                    <input type="text" name="thumbnails" class="form-control mb-2" placeholder="URLs de imágenes (separadas por coma, opcional)" />
                    <button type="submit" class="btn btn-success w-100">
                        <i class="fas fa-save"></i> Agregar Producto
                    </button>
                </form>
            </div>
        </div>
    </div>

    {{!-- Tabla de productos --}}
    <div class="col-md-8">
        <div class="card shadow-sm">
            <div class="card-header bg-dark text-white">
                <div class="d-flex justify-content-between align-items-center mb-2">
                    <span><i class="fas fa-list"></i> Listado de Productos</span>
                    <div class="d-flex align-items-center">
                        <span class="badge bg-light text-dark me-3">Página {{pagination.page}} de {{pagination.totalPages}}</span>
                        <form id="searchForm" class="d-flex" onsubmit="event.preventDefault(); searchProductById();">
                            <input 
                              type="text"
                              id="searchIdInput"
                              class="form-control form-control-sm me-2"
                              placeholder="Buscar por ID"
                            />
                            <button class="btn btn-sm btn-outline-light" type="submit">
                                <i class="fas fa-search"></i>
                            </button>
                        </form>
                    </div>
                </div>
                {{!-- Filtros --}}
                <form method="GET" action="/api/products/view" class="d-flex gap-2 flex-wrap">
                    <input type="text" name="query" class="form-control form-control-sm" style="width: 150px;" placeholder="Categoría..." value="{{pagination.query}}" />
                    <select name="status" class="form-select form-select-sm" style="width: auto;">
                        <option value="">Todos</option>
                        <option value="available" {{#if (eq pagination.status 'available')}}selected{{/if}}>Disponibles </option>
                        <option value="unavailable" {{#if (eq pagination.status 'unavailable')}}selected{{/if}}>Sin stock</option>
                    </select>
                    <select name="sort" class="form-select form-select-sm" style="width: auto;">
                        <option value="">Sin ordenar</option>
                        <option value="asc" {{#if (eq pagination.sort 'asc')}}selected{{/if}}>Precio: Menor a Mayor</option>
                        <option value="desc" {{#if (eq pagination.sort 'desc')}}selected{{/if}}>Precio: Mayor a Menor</option>
                    </select>
                    <select name="limit" class="form-select form-select-sm" style="width: auto;">
                        <option value="5" {{#if (eq pagination.limit 5)}}selected{{/if}}>5 por página</option>
                        <option value="10" {{#if (eq pagination.limit 10)}}selected{{/if}}>10 por página</option>
                        <option value="20" {{#if (eq pagination.limit 20)}}selected{{/if}}>20 por página</option>
                    </select>
                    <button type="submit" class="btn btn-sm btn-primary">
                        <i class="fas fa-filter"></i> Filtrar
                    </button>
                </form>
            </div>
            <div class="card-body p-0">
                <div class="table-responsive">
                    <table class="table table-striped table-hover mb-0">
                        <thead class="table-dark">
                            <tr>
                                <th><i class="fas fa-tag"></i> Título</th>
                                <th><i class="fas fa-barcode"></i> Código</th>
                                <th><i class="fas fa-dollar-sign"></i> Precio</th>
                                <th><i class="fas fa-cubes"></i> Stock</th>
                                <th><i class="fas fa-folder"></i> Categoría</th>
                                <th class="text-end"><i class="fas fa-cogs"></i> Acciones</th>
                            </tr>
                        </thead>
                        <tbody>
                            {{#each products}}
                            <tr>
                                <td>{{this.title}}</td>
                                <td>{{this.code}}</td>
                                <td>${{this.price}}</td>
                                <td>
                                    {{#if this.stock}}
                                        <span class="badge bg-success">{{this.stock}}</span>
                                    {{else}}
                                        <span class="badge bg-danger">Sin stock</span>
                                    {{/if}}
                                </td>
                                <td>{{this.category}}</td>
                                <td class="text-end">
                                    <a href="/api/products/{{this._id}}" class="btn btn-sm btn-info me-1" title="Ver detalle">
                                        <i class="fas fa-eye"></i>
                                    </a>
                                    <button type="button" class="btn btn-sm btn-danger" title="Eliminar" onclick="deleteProduct('{{this._id}}')">
                                        <i class="fas fa-trash"></i>
                                    </button>
                                </td>
                            </tr>
                            {{else}}
                            <tr>
                                <td colspan="6" class="text-center text-muted py-4">
                                    <i class="fas fa-inbox fa-2x mb-2 d-block"></i>
                                    No hay productos cargados aún.
                                </td>
                            </tr>
                            {{/each}}
                        </tbody>
                    </table>
                </div>
            </div>
            {{!-- Paginación --}}
            <div class="card-footer d-flex justify-content-between align-items-center">
                <div>
                    {{#if pagination.hasPrevPage}}
                    <a href="/api/products/view?page={{pagination.prevPage}}&limit={{pagination.limit}}{{#if pagination.query}}&query={{pagination.query}}{{/if}}{{#if pagination.sort}}&sort={{pagination.sort}}{{/if}}{{#if pagination.status}}&status={{pagination.status}}{{/if}}" class="btn btn-sm btn-outline-primary">
                        <i class="fas fa-chevron-left"></i> Anterior
                    </a>
                    {{else}}
                    <button class="btn btn-sm btn-outline-secondary" disabled>
                        <i class="fas fa-chevron-left"></i> Anterior
                    </button>
                    {{/if}}
                </div>
                <span class="text-muted">Página {{pagination.page}} de {{pagination.totalPages}}</span>
                <div>
                    {{#if pagination.hasNextPage}}
                    <a href="/api/products/view?page={{pagination.nextPage}}&limit={{pagination.limit}}{{#if pagination.query}}&query={{pagination.query}}{{/if}}{{#if pagination.sort}}&sort={{pagination.sort}}{{/if}}{{#if pagination.status}}&status={{pagination.status}}{{/if}}" class="btn btn-sm btn-outline-primary">
                        Siguiente <i class="fas fa-chevron-right"></i>
                    </a>
                    {{else}}
                    <button class="btn btn-sm btn-outline-secondary" disabled>
                        Siguiente <i class="fas fa-chevron-right"></i>
                    </button>
                    {{/if}}
                </div>
            </div>
                </div>
        </div>
</div>
